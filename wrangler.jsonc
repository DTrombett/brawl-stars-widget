{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "brawl-stars-widget",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-07",
	"observability": { "enabled": true },
	"upload_source_maps": true,
	"assets": { "directory": "./assets", "not_found_handling": "404-page" },
	"route": {
		"pattern": "brawl-stars-widget.trombett.org",
		"custom_domain": true,
	},
	"triggers": {
		"crons": ["0 */1 * * *"],
	},
	"workflows": [
		{
			"name": "update-widget",
			"class_name": "UpdateWidget",
			"binding": "UPDATE_WIDGET",
		},
	],
}
